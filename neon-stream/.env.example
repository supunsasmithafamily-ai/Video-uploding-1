# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_ID=price_...           # the $5/month recurring Price
STRIPE_WEBHOOK_SECRET=whsec_...     # from Stripe CLI or Dashboard webhook config

# Firebase Admin (Project settings -> Service accounts -> Generate new private key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# Your deployed app URL (used for Stripe redirect URLs)
APP_URL=https://your-app.vercel.app

# Cloudflare R2 (video storage — S3-compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=neon-stream-videos
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev   # or your custom domain
